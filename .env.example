# Alpaca
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Database
DATABASE_URL=sqlite:///./trading.db

# Trading
UNIVERSE=AAPL,MSFT,NVDA,AVGO,AMD,GOOGL,META,NFLX,AMZN,TSLA,HD,LULU,COST,KO,WMT,JPM,V,MA,JNJ,UNH,LLY,CAT,URI,AXON,XOM,CVX,FCX,NEE,AMT,ELF
APPROVAL_TIMEOUT_MINUTES=15
MAX_CONCURRENT_POSITIONS=5
DAILY_MAX_LOSS_PCT=2.0
# Comma-separated Telegram user IDs who can approve/reject trades and run admin commands.
# Everyone else in the group can read signals but not interact.
# Get your ID by messaging @userinfobot on Telegram.
TRADER_USER_IDS=123456789,987654321
